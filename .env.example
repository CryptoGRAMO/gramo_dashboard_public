# =============================================================================
# GRAMO Dashboard — Environment Variables
# =============================================================================
# -----------------------------------------------------------------------------
# Database (MySQL)
# -----------------------------------------------------------------------------
# Hostname of your MySQL server (localhost for local dev, RDS endpoint for AWS, etc.)
DATABASE_HOST=localhost
# Database name
DATABASE_NAME=gramo_db
# Database user with read/write access
DATABASE_USER=your-db-user
# Database password
DATABASE_PASS=your-db-password

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
# SMTP server used by Django to send activation & notification emails
EMAIL_HOST=smtp.your-provider.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password

# -----------------------------------------------------------------------------
# Algorand Node
# -----------------------------------------------------------------------------
# Algod API endpoint — use a public node (e.g., Nodely) or your own
# Testnet: https://testnet-api.4160.nodely.dev
# Mainnet: https://mainnet-api.4160.nodely.dev
ALGOD_ADDRESS_FOR_TESTING=https://mainnet-api.4160.nodely.dev
# Algod API token (required by some node providers like PureStake)
ALGOD_TOKEN_FOR_TESTING=your-algod-token

# -----------------------------------------------------------------------------
# Algorand Distribution Wallet
# -----------------------------------------------------------------------------
# Public address of the wallet that funds new user wallets and distributes GRAMO
SENDER_ADDRESS_FOR_TESTING=your-distribution-wallet-public-address
# Private key (base64) of the distribution wallet — KEEP THIS SECRET
SK_FOR_TESTING=your-distribution-wallet-private-key-NEVER-COMMIT-THIS

# -----------------------------------------------------------------------------
# WooCommerce API (optional — used for e-commerce integration)
# -----------------------------------------------------------------------------
# Consumer key from WooCommerce > Settings > REST API
CONSUMER_KEY=ck_your-woocommerce-consumer-key
# Consumer secret from WooCommerce > Settings > REST API
CONSUMER_SECRET=cs_your-woocommerce-consumer-secret
